{
  "manifest_version": 3,
  "name": "Khan Academy Video for Math Academy",
  "version": "4.0.0",
  "description": "One-click Khan Academy video for the topic you're working on. Loads in-page on Math Academy. Learns from your overrides — bad guesses become good ones. Optional YouTube API for live search.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["https://www.googleapis.com/*"],
  "content_scripts": [
    {
      "matches": ["*://*.mathacademy.com/*"],
      "js": ["khan-topics.js", "db.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["player.html"],
      "matches": ["*://*.mathacademy.com/*"]
    }
  ]
}
